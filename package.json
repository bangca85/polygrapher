{
  "name": "polygrapher",
  "version": "0.5.1",
  "description": "Zero-config CLI that generates instant, interactive codebase maps",
  "type": "module",
  "bin": {
    "polygrapher": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "codebase",
    "graph",
    "architecture",
    "visualization",
    "cli",
    "tree-sitter"
  ],
  "author": "Bradley",
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0",
    "cytoscape": "^3.33.1",
    "ignore": "^7.0.5",
    "open": "^10.1.0",
    "web-tree-sitter": "^0.24.7"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tree-sitter-cli": "^0.24.3",
    "tree-sitter-go": "^0.23.4",
    "tree-sitter-javascript": "^0.21.3",
    "tree-sitter-typescript": "^0.23.2",
    "tsup": "^8.1.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "grammars",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bangca85/polygrapher.git"
  },
  "homepage": "https://github.com/bangca85/polygrapher#readme",
  "bugs": {
    "url": "https://github.com/bangca85/polygrapher/issues"
  }
}
